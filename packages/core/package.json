{
  "name": "@rosm/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": "./src/*.ts",
    "./appConfig.json": "./appConfig.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@rosm/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "react": "19.2.4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.9",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
