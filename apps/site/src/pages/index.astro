---
import Layout from "@/layouts/Layout.astro";
import BetaCta from "@/components/BetaCta.svelte";
import DemoRunMap from "@/components/DemoRunMap.svelte";
import LiveFountainMap from "@/components/LiveFountainMap.svelte";
import FountainLeaderboard from "@/components/FountainLeaderboard.svelte";
import FreshnessLegend from "@/components/FreshnessLegend.svelte";

export const prerender = true;

// Torn-surface silhouette for the manifesto plate. Irregular px offsets along the
// top and bottom edges read as a hand-torn strip; the left/right sides stay
// straight for the full-bleed section. Offsets are hardcoded — not random.
// clip-path and the raising drop-shadow live on separate elements: on one element
// the clip runs after the filter and would clip the shadow away to nothing.
const tornShadow =
  "filter: drop-shadow(0 2px 3px rgba(60, 48, 24, 0.32)) drop-shadow(0 9px 18px rgba(60, 48, 24, 0.24));";
const tornClip = `clip-path: polygon(
  0% 10px, 4% 2px, 7% 18px, 13% 4px, 17% 21px, 21% 7px, 26% 14px, 31% 1px,
  34% 19px, 40% 5px, 44% 22px, 49% 9px, 53% 3px, 58% 17px, 63% 6px, 68% 20px,
  71% 11px, 77% 2px, 82% 16px, 86% 5px, 91% 23px, 96% 8px, 100% 13px,
  100% calc(100% - 11px), 96% calc(100% - 3px), 91% calc(100% - 19px),
  86% calc(100% - 6px), 82% calc(100% - 22px), 77% calc(100% - 8px),
  71% calc(100% - 15px), 68% calc(100% - 2px), 63% calc(100% - 20px),
  58% calc(100% - 5px), 53% calc(100% - 23px), 49% calc(100% - 9px),
  44% calc(100% - 4px), 40% calc(100% - 17px), 34% calc(100% - 7px),
  31% calc(100% - 21px), 26% calc(100% - 12px), 21% calc(100% - 3px),
  17% calc(100% - 18px), 13% calc(100% - 6px), 7% calc(100% - 22px),
  4% calc(100% - 9px), 0% calc(100% - 14px)
);`;

// Decorative topographic contour paths: a single family that fades to nothing
// as it descends. Retains the total row count of the previous two families.
const contourRows = 16;
const contourLines = Array.from({ length: contourRows }, (_, i) => {
  const o = i * 30;
  return {
    d: `M-50 ${100 + o} C 200 ${40 + o}, 360 ${200 + o}, 560 ${160 + o} S 920 ${40 + o}, 1260 ${140 + o}`,
    opacity: 0.28 * (1 - i / (contourRows - 1)),
  };
});
---

<Layout>
  <main class="surface-grain bg-surface font-body text-base relative">
    <div class="absolute top-0 left-0 z-10 flex items-center gap-2.5 px-5 pt-5">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/icons/icon.svg" alt="ROSM" class="h-12 w-auto" />
        <span class="font-hero text-3xl leading-none tracking-tight md:text-4xl translate-y-1" style="color: #2A5F2B">ROSM</span>
      </a>
    </div>

    {/* HERO */}
    <section class="relative overflow-hidden">
      <svg
        class="pointer-events-none absolute inset-0 h-full w-full" style="color: #0E85C6"
        viewBox="0 0 1200 600"
        fill="none"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {contourLines.map((l) => (
          <path d={l.d} stroke="currentColor" stroke-width="1" opacity={l.opacity} />
        ))}
      </svg>

      <div class="relative mx-auto max-w-6xl px-5 pt-24 pb-16 md:pt-32 md:pb-24">
        {/* Mobile: title -> map -> subtitle (flex column). Desktop: map spans the
            left column, title + subtitle stack in the right column (grid). */}
        <div
          class="flex flex-col items-start gap-8 md:grid md:grid-cols-[46%_1fr] md:items-center md:gap-x-12 md:gap-y-4"
        >
          <h1
            class="reveal font-hero max-w-5xl text-[clamp(3.2rem,14vw,5.8rem)] leading-[0.9] font-bold tracking-tight md:col-start-2 md:row-start-1 md:self-end"
            style="transition-delay: 0.1s"
          >
            Run & Verify
          </h1>

          {/* Interactive demo of the run + edit flow, framed like a print plate. */}
          <div
            class="reveal border-base/10 bg-info relative w-full overflow-hidden rounded-xl border md:col-start-1 md:row-span-2 md:self-center"
            style="transition-delay: 0.05s"
          >
            <div class="hero-map relative isolate z-0 h-[clamp(300px,40vw,460px)] w-full">
              <DemoRunMap client:only="svelte">
                {/* Server-rendered spinner: visible instantly, before the Svelte
                    island's JS downloads and hydrates. Replaced on hydration. */}
                <div
                  slot="fallback"
                  style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: #0E85C6;"
                >
                  <svg
                    style="width: 2rem; height: 2rem; color: #fff; animation: spin 1s linear infinite;"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                  >
                    <circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path
                      style="opacity: 0.75;"
                      fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    ></path>
                  </svg>
                </div>
              </DemoRunMap>
            </div>
          </div>

          <div
            class="reveal flex flex-col items-start gap-6 md:col-start-2 md:row-start-2 md:self-start"
            style="transition-delay: 0.16s"
          >
            <p class="text-muted max-w-xl text-xl leading-relaxed">
              A runner-sourced map of public fountains in D.C.
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/dc-drinking-fountains"
                class="inline-flex items-center gap-2.5 self-end rounded-sm border border-base/20 bg-transparent px-6 py-3 text-lg font-bold text-base transition hover:bg-base/5 md:self-start"
              >
                <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true" class="h-6 w-6">
                  <path
                    d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75ZM128,216a72.08,72.08,0,0,1-72-72c0-57.23,55.47-105,72-118,16.53,13,72,60.75,72,118A72.08,72.08,0,0,1,128,216Zm55.89-62.66a57.6,57.6,0,0,1-46.56,46.55A8.75,8.75,0,0,1,136,200a8,8,0,0,1-1.3-15.89c16.94-2.79,31.2-17,34-34A8,8,0,0,1,184.4,148,8.11,8.11,0,0,1,183.89,153.34Z"
                  ></path>
                </svg>
                Find Water Now
              </a>
              <BetaCta client:load />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* MANIFESTO SPLIT — a raised, hand-torn surface strip over the page.
        Wrapper casts the shadow; inner section carries the torn clip. */}
    <div class="relative z-10 -my-6" style={tornShadow}>
      <section class="bg-blue" style={tornClip}>
        <div class="reveal mx-auto max-w-3xl px-5 py-20 md:py-28">
          <h2 class="font-hero text-[clamp(2rem,5vw,3.4rem)] leading-[1.05] font-bold tracking-tight text-light">
            The Problem
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-white/65">
            Despite DC's many public drbaseing fountains, there is no reliable way to know where they
            all are. And then, many are out of order. This is bad for everyone, especially folks who
            spend a disproportionate amount of time outdoors—thbase runners, tourists, and the
            homeless.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-white/65">
            By building a robust, locally-sourced map of public drbaseing water, we can improve the
            utility of this existing public good. This removes the guesswork of where to find the
            nearest fountain as well as the uncertainty of whether that fountain will work.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-white/65">
            In practice, this produces immediate and long-term benefits:
          </p>
          <ul class="mt-4 list-disc space-y-1 pl-6 text-lg leading-relaxed text-white/65">
            <li>
              <span class="font-medium">Immediately,</span> anyone can reliably locate the nearest
              working fountain
            </li>
            <li>
              <span class="font-medium">Long-term,</span> 311 can have rapid visibility for when
              fountains break
            </li>
          </ul>
        </div>
      </section>
    </div>

    {/* THE STATE OF THE FOUNTAINS — leaderboard + live coverage map */}
    <section>
      <div class="mx-auto max-w-6xl px-5 py-20 md:py-28">
        <h2
          class="reveal font-hero text-[clamp(2rem,5.5vw,3.6rem)] leading-tight font-bold tracking-tight uppercase"
        >
          The State of the Fountains
        </h2>
        <p class="reveal text-muted mt-8 max-w-2xl text-lg leading-relaxed" style="transition-delay: 0.1s">
          Here's a live coverage map of the fountains in DC.
        </p>

        {/* Contributor leaderboard — self-hides when there's no attributed edit data yet. */}
        <div class="reveal mt-12" style="transition-delay: 0.14s">
          <span class="font-mono text-[0.65rem] font-medium tracking-[0.22em] uppercase" style="color: #F38300">
            Top contributors
          </span>
          <FountainLeaderboard client:visible class="mt-6" />
        </div>

        <div
          class="reveal mt-12 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 px-1 pb-2"
          style="transition-delay: 0.18s"
        >
          <span class="font-mono text-[0.65rem] font-medium tracking-[0.22em] uppercase" style="color: #F38300">
            Live
          </span>
          <FreshnessLegend client:visible />
        </div>
        <div
          class="reveal border-base/10 bg-info relative overflow-hidden rounded-xl border"
          style="transition-delay: 0.22s"
        >
          <div class="relative isolate z-0 h-[clamp(340px,48vw,560px)] w-full">
            <LiveFountainMap client:only="svelte" />
          </div>
        </div>
      </div>
    </section>

    {/* BOTTOM CTA */}
    <section class="border-border border-t">
      <div class="reveal mx-auto flex max-w-6xl flex-col items-center gap-6 px-5 py-16 md:py-24">
        <h2
          class="font-hero text-center text-[clamp(1.75rem,4vw,2.75rem)] leading-tight font-bold tracking-tight"
        >
          Help map the fountains.
        </h2>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/dc-drinking-fountains"
            class="inline-flex items-center gap-2.5 rounded-sm border border-base/20 bg-transparent px-6 py-3 text-lg font-bold text-base transition hover:bg-base/5"
          >
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true" class="h-6 w-6">
              <path
                d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75ZM128,216a72.08,72.08,0,0,1-72-72c0-57.23,55.47-105,72-118,16.53,13,72,60.75,72,118A72.08,72.08,0,0,1,128,216Zm55.89-62.66a57.6,57.6,0,0,1-46.56,46.55A8.75,8.75,0,0,1,136,200a8,8,0,0,1-1.3-15.89c16.94-2.79,31.2-17,34-34A8,8,0,0,1,184.4,148,8.11,8.11,0,0,1,183.89,153.34Z"
              ></path>
            </svg>
            Find Water Now
          </a>
          <BetaCta client:load />
        </div>
      </div>
    </section>

    {/* FOOTER */}
    <footer class="border-border border-t">
      <div class="text-muted mx-auto flex max-w-6xl items-center justify-center gap-4 px-5 py-8 text-sm">
        <span>
          Made with{" "}
          <svg
            viewBox="0 0 256 256"
            fill="currentColor"
            aria-hidden="true"
            class="inline-block h-4 w-4 align-middle" style="color: #0E85C6"
          >
            <path
              d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75Z"
            ></path>
          </svg>{" "}
          by{" "}
          <a
            href="https://jamesm.it/about"
            target="_blank"
            rel="noopener noreferrer"
            class="text-link decoration-link/50 hover:decoration-link font-medium underline underline-offset-4"
          >
            James Mitofinfo
          </a>
        </span>
      </div>
    </footer>
  </main>

  <script>
    // Scroll-reveal (was framer-motion fadeUp): reveal each `.reveal` block as it
    // crosses into view, once. Positive bottom rootMargin extends the trigger zone
    // below the viewport so blocks start revealing while still under the fold.
    const els = document.querySelectorAll<HTMLElement>(".reveal");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            obs.unobserve(entry.target);
            // Free GPU layer once animation is done — will-change is expensive to hold
            (entry.target as HTMLElement).addEventListener(
              "transitionend",
              () => { (entry.target as HTMLElement).style.willChange = "auto"; },
              { once: true },
            );
          }
        }
      },
      { rootMargin: "0px 0px 20% 0px", threshold: 0 },
    );
    els.forEach((el) => io.observe(el));
  </script>
</Layout>
