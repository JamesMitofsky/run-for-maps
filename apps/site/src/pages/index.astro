---
import Layout from "@/layouts/Layout.astro";
import BetaCta from "@/components/BetaCta.svelte";
import DemoRunMap from "@/components/DemoRunMap.svelte";
import LiveFountainMap from "@/components/LiveFountainMap.svelte";
import FountainLeaderboard from "@/components/FountainLeaderboard.svelte";
import FreshnessLegend from "@/components/FreshnessLegend.svelte";

export const prerender = true;

// Wave-cut silhouette for the manifesto plate. The top and bottom edges roll as
// smooth waves at uneven intervals; the left/right sides stay straight for the
// full-bleed section. Coordinates are objectBoundingBox units (0–1) so the clip
// scales with the element and stays responsive; cubic beziers give true curves,
// which polygon() cannot. Offsets are hardcoded — not random.
// clip-path and the raising drop-shadow live on separate elements: on one element
// the clip runs after the filter and would clip the shadow away to nothing.
const tornShadow =
  "filter: drop-shadow(0 2px 3px rgba(60, 48, 24, 0.32)) drop-shadow(0 9px 18px rgba(60, 48, 24, 0.24));";

// Smooth wave through a list of points. Each segment is a cubic whose control
// points sit at the horizontal midpoint, so consecutive crests/troughs blend
// into a continuous curve rather than kinking at each point.
const r = (n: number) => Math.round(n * 10000) / 10000;
const waveThrough = (pts: { x: number; y: number }[]) =>
  pts
    .slice(1)
    .reduce((d, p, i) => {
      const prev = pts[i];
      const mx = r(prev.x + (p.x - prev.x) / 2);
      return `${d} C ${mx} ${r(prev.y)}, ${mx} ${r(p.y)}, ${r(p.x)} ${r(p.y)}`;
    }, `M ${r(pts[0].x)} ${r(pts[0].y)}`);

// Uneven wave-crest positions along the width; y alternates crest (0) / trough.
const topWave = [
  { x: 0, y: 0.02 }, { x: 0.09, y: 0 }, { x: 0.15, y: 0.03 }, { x: 0.27, y: 0.005 },
  { x: 0.34, y: 0.028 }, { x: 0.48, y: 0 }, { x: 0.55, y: 0.025 }, { x: 0.68, y: 0.004 },
  { x: 0.76, y: 0.03 }, { x: 0.88, y: 0.008 }, { x: 1, y: 0.02 },
];
const bottomWave = [
  { x: 1, y: 0.98 }, { x: 0.88, y: 1 }, { x: 0.76, y: 0.972 }, { x: 0.68, y: 0.996 },
  { x: 0.55, y: 0.975 }, { x: 0.48, y: 1 }, { x: 0.34, y: 0.978 }, { x: 0.27, y: 0.996 },
  { x: 0.15, y: 0.97 }, { x: 0.09, y: 0.995 }, { x: 0, y: 0.98 },
];
const tornPath = `${waveThrough(topWave)} L ${r(bottomWave[0].x)} ${r(bottomWave[0].y)} ${waveThrough(bottomWave).slice(1)} Z`;
const tornClip = "clip-path: url(#manifesto-wave);";

// Decorative topographic contour paths: a single family that fades to nothing
// as it descends. Retains the total row count of the previous two families.
const contourRows = 16;
const contourLines = Array.from({ length: contourRows }, (_, i) => {
  const o = i * 30;
  return {
    d: `M-50 ${100 + o} C 200 ${40 + o}, 360 ${200 + o}, 560 ${160 + o} S 920 ${40 + o}, 1260 ${140 + o}`,
    opacity: 0.16 * (i / (contourRows - 1)),
  };
});
---

<Layout>
  <main class="bg-surface font-body text-base relative">
    {/* HERO */}
    <section class="relative overflow-hidden">
      <svg
        class="pointer-events-none absolute inset-0 h-full w-full" style="color: #0E85C6"
        viewBox="0 0 1200 600"
        fill="none"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        {contourLines.map((l) => (
          <path d={l.d} stroke="currentColor" stroke-width="1" opacity={l.opacity} />
        ))}
      </svg>

      <div class="relative mx-auto max-w-6xl px-5 pt-8 pb-16 md:pt-12 md:pb-24">
        {/* Mobile: title -> map -> subtitle (flex column). Desktop: map spans the
            left column, title + subtitle stack in the right column (grid). */}
        <div
          class="flex flex-col items-start gap-8 md:grid md:grid-cols-[46%_1fr] md:items-center md:gap-x-12 md:gap-y-4"
        >
          <h1
            class="reveal font-hero text-hero max-w-5xl text-[clamp(3.2rem,14vw,5.8rem)] leading-[0.9] font-bold tracking-tight md:col-start-2 md:row-start-1 md:self-end"
            style="transition-delay: 0.1s"
          >
            Run & Verify
          </h1>

          {/* Interactive demo of the run + edit flow, framed like a print plate. */}
          <div
            class="reveal bg-info relative w-full overflow-hidden rounded-xl shadow-lg md:col-start-1 md:row-span-2 md:self-center"
            style="transition-delay: 0.05s"
          >
            <div class="hero-map relative isolate z-0 h-[clamp(300px,40vw,460px)] w-full">
              <DemoRunMap client:only="svelte">
                {/* Server-rendered spinner: visible instantly, before the Svelte
                    island's JS downloads and hydrates. Replaced on hydration. */}
                <div
                  slot="fallback"
                  style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: #0E85C6;"
                >
                  <svg
                    style="width: 2rem; height: 2rem; color: #fff; animation: spin 1s linear infinite;"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                  >
                    <circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path
                      style="opacity: 0.75;"
                      fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    ></path>
                  </svg>
                </div>
              </DemoRunMap>
            </div>
          </div>

          <div
            class="reveal flex flex-col items-start gap-6 md:col-start-2 md:row-start-2 md:self-start"
            style="transition-delay: 0.16s"
          >
            <p class="text-muted max-w-xl text-xl leading-relaxed">
              A runner-sourced map of DC's drinking fountains.
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/dc-drinking-fountains"
                class="inline-flex items-center gap-2.5 rounded-xl border border-blue bg-transparent px-6 py-3 text-lg font-bold text-blue transition hover:bg-blue/5"
              >
                <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true" class="h-6 w-6">
                  <path
                    d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75ZM128,216a72.08,72.08,0,0,1-72-72c0-57.23,55.47-105,72-118,16.53,13,72,60.75,72,118A72.08,72.08,0,0,1,128,216Zm55.89-62.66a57.6,57.6,0,0,1-46.56,46.55A8.75,8.75,0,0,1,136,200a8,8,0,0,1-1.3-15.89c16.94-2.79,31.2-17,34-34A8,8,0,0,1,184.4,148,8.11,8.11,0,0,1,183.89,153.34Z"
                  ></path>
                </svg>
                Find Water Now
              </a>
              <BetaCta client:load />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* MANIFESTO SPLIT — a raised, hand-torn surface strip over the page.
        Wrapper casts the shadow; inner section carries the torn clip. */}
    <div class="relative z-10 -my-6" style={tornShadow}>
      <svg width="0" height="0" class="absolute" aria-hidden="true">
        <clipPath id="manifesto-wave" clipPathUnits="objectBoundingBox">
          <path d={tornPath} />
        </clipPath>
      </svg>
      <section class="bg-blue" style={tornClip}>
        <div class="reveal mx-auto max-w-3xl px-5 py-20 md:py-28">
          <h2 class="font-hero text-[clamp(2rem,5vw,3.4rem)] leading-[1.05] font-bold tracking-tight text-light">
            The Problem
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-white/85">
            If you're anywhere other than the National Mall, it's hard to know where the public drinking fountains are. Or maybe you've found a map some folks made together, but when you arrive at the fountain, it's either out of order or <em>even removed</em>!
            This unreliable access to free water—no less in a place with some crazy summer heat—is bad for everyone, especially people who
            spend more time outdoors—think runners, tourists, and the homeless.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-white/85">
            ROSM tackles this problem by making information about each fountain detailed. Things like: is the fountain still here? is it out of order? when was it last checked? who checked it?
            With no expertise in municipal planning, in seems to me that installing the fountain should be the hardest part, not finding it.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-white/85">
            This stands to promote both immediate and long-term benefits:
          </p>
          <ul class="mt-4 list-disc space-y-1 pl-6 text-lg leading-relaxed text-white/85">
            <li>
              <span class="font-medium">Immediately,</span> anyone can reliably locate the nearest
              working fountain
            </li>
            <li>
              <span class="font-medium">Long-term,</span> 311 can be more tightly looped in to when repairs are necessary
            </li>
          </ul>
        </div>
      </section>
    </div>

    {/* THE STATE OF THE FOUNTAINS — leaderboard + live coverage map */}
    <section>
      <div class="mx-auto max-w-6xl px-5 pt-20 pb-10 md:pt-28 md:pb-12">
        <h2
          class="reveal font-hero text-hero text-[clamp(2rem,5.5vw,3.6rem)] leading-tight font-bold tracking-tight uppercase"
        >
          The State of the Fountains
        </h2>
        <p class="reveal text-muted mt-8 max-w-2xl text-lg leading-relaxed" style="transition-delay: 0.1s">
          Here's a live coverage map of the fountains in DC.
        </p>

        {/* Contributor leaderboard — self-hides when there's no attributed edit data yet. */}
        <div class="reveal mt-12" style="transition-delay: 0.14s">
          <span class="font-mono text-[0.65rem] font-medium tracking-[0.22em] uppercase" style="color: #F38300">
            Top contributors
          </span>
          <FountainLeaderboard client:visible class="mt-6" />
        </div>

        <div
          class="reveal mt-12 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 px-1 pb-2"
          style="transition-delay: 0.18s"
        >
          <span class="font-mono text-[0.65rem] font-medium tracking-[0.22em] uppercase" style="color: #F38300">
            Live
          </span>
          <FreshnessLegend client:visible />
        </div>
        <div
          class="reveal border-base/10 bg-info relative overflow-hidden rounded-xl border"
          style="transition-delay: 0.22s"
        >
          <div class="relative isolate z-0 h-[clamp(340px,48vw,560px)] w-full">
            <LiveFountainMap client:only="svelte" />
          </div>
        </div>
      </div>
    </section>

    {/* BOTTOM CTA */}
    <section>
      <div class="reveal mx-auto flex max-w-6xl flex-col items-center gap-6 px-5 py-12 md:py-16">
        <h2
          class="font-hero text-hero text-center text-[clamp(2rem,5vw,3.4rem)] leading-tight font-bold tracking-tight"
        >
          Help map the fountains!
        </h2>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/dc-drinking-fountains"
            class="inline-flex items-center gap-2.5 rounded-xl border border-blue bg-transparent px-6 py-3 text-lg font-bold text-blue transition hover:bg-blue/5"
          >
            <svg viewBox="0 0 256 256" fill="currentColor" aria-hidden="true" class="h-6 w-6">
              <path
                d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75ZM128,216a72.08,72.08,0,0,1-72-72c0-57.23,55.47-105,72-118,16.53,13,72,60.75,72,118A72.08,72.08,0,0,1,128,216Zm55.89-62.66a57.6,57.6,0,0,1-46.56,46.55A8.75,8.75,0,0,1,136,200a8,8,0,0,1-1.3-15.89c16.94-2.79,31.2-17,34-34A8,8,0,0,1,184.4,148,8.11,8.11,0,0,1,183.89,153.34Z"
              ></path>
            </svg>
            Find Water Now
          </a>
          <BetaCta client:load />
        </div>
      </div>
    </section>

    {/* FOOTER */}
    <footer>
      <div class="text-muted mx-auto flex max-w-6xl items-center justify-center gap-4 px-5 py-8 text-sm">
        <span>
          Made with{" "}
          <svg
            viewBox="0 0 256 256"
            fill="currentColor"
            aria-hidden="true"
            class="inline-block h-4 w-4 align-middle" style="color: #0E85C6"
          >
            <path
              d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75Z"
            ></path>
          </svg>{" "}
          by{" "}
          <a
            href="https://jamesm.it/about"
            target="_blank"
            rel="noopener noreferrer"
            class="text-link decoration-link/50 hover:decoration-link font-medium underline underline-offset-4"
          >
            James Mitofinfo
          </a>
        </span>
      </div>
    </footer>
  </main>

  <script>
    // Scroll-reveal (was framer-motion fadeUp): reveal each `.reveal` block as it
    // crosses into view, once. Positive bottom rootMargin extends the trigger zone
    // below the viewport so blocks start revealing while still under the fold.
    const els = document.querySelectorAll<HTMLElement>(".reveal");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            obs.unobserve(entry.target);
            // Free GPU layer once animation is done — will-change is expensive to hold
            (entry.target as HTMLElement).addEventListener(
              "transitionend",
              () => { (entry.target as HTMLElement).style.willChange = "auto"; },
              { once: true },
            );
          }
        }
      },
      { rootMargin: "0px 0px 20% 0px", threshold: 0 },
    );
    els.forEach((el) => io.observe(el));
  </script>
</Layout>
