---
import Layout from "@/layouts/Layout.astro";
import LiveFountainMap from "@/components/LiveFountainMap.svelte";
import FreshnessLegend from "@/components/FreshnessLegend.svelte";

export const prerender = true;
---

<Layout
  title="DC Drinking Fountains — Live Map"
  description="A live map of public drinking fountains in Washington, DC, sourced from OpenStreetMap and graded by verification recency."
>
  <main class="bg-surface font-body text-base relative min-h-screen">
    <section>
      <div class="mx-auto max-w-6xl px-5 pt-4 pb-12 md:pb-20">
        <h1
          class="font-hero text-hero text-[clamp(2rem,5.5vw,3.6rem)] leading-tight font-bold tracking-tight uppercase"
        >
          DC Drinking Fountains
        </h1>
        <div class="mt-10 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 px-1 pb-2">
          <span
            class="font-mono text-[0.65rem] font-medium tracking-[0.22em] uppercase"
            style="color: #F38300"
          >
            Live
          </span>
          <FreshnessLegend client:visible />
        </div>

        <div class="border-base/10 bg-info relative overflow-hidden rounded-xl border">
          <div class="relative isolate z-0 h-[clamp(420px,72vh,760px)] w-full">
            <LiveFountainMap client:only="svelte" />
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
