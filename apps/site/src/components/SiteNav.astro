---
// Top-of-page navigation for the marketing landing. The only action is the beta
// sign-up button, which opens the same modal as the hero CTA by dispatching an
// `open-beta-modal` window event that BetaCta.svelte listens for.
---

<header class="bg-paper-deep sticky top-0 z-[110] pt-[env(safe-area-inset-top)] shadow-md">
  <nav class="mx-auto max-w-6xl px-5">
    <div class="flex items-center justify-between gap-4 py-4">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/icons/icon.svg" alt="Run Verified Fountains" class="h-8 w-auto" />
        <span class="font-hero text-ink text-2xl tracking-tight md:text-3xl">
          Run Verified Fountains
        </span>
      </a>

      <button
        type="button"
        data-open-beta
        class="border-sky-deep text-sky-deep hover:bg-sky-deep hover:text-paper inline-flex shrink-0 items-center rounded-sm border px-5 py-2 text-base font-bold whitespace-nowrap transition"
      >
        Join the Beta
      </button>
    </div>
  </nav>
</header>

<script>
  // Bridge to the BetaCta.svelte island: clicking the nav button dispatches the
  // event that opens the shared beta sign-up modal.
  document.querySelector("[data-open-beta]")?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("open-beta-modal"));
  });
</script>
