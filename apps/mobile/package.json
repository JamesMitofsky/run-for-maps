{
  "name": "@rosm/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:local": "eas build --profile preview --platform ios --local",
    "build:ios:testflight": "eas build --profile production --platform ios --local --output ./build/rosm.ipa",
    "submit:testflight": "./scripts/submit-testflight.sh",
    "uniwind:types": "uniwind generate-artifacts --css ./src/global.css --dts ./src/uniwind-types.d.ts",
    "typecheck": "pnpm uniwind:types && tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@maplibre/maplibre-react-native": "^11.3.6",
    "@rosm/core": "workspace:*",
    "expo": "~57.0.8",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.8",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "^57.0.1",
    "expo-keep-awake": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-location": "~57.0.6",
    "expo-network": "~57.0.1",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.7",
    "expo-splash-screen": "~57.0.5",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-task-manager": "~57.0.6",
    "expo-web-browser": "~57.0.2",
    "phosphor-react-native": "^3.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.26.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "uniwind": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.4",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "expo-mcp": "~0.2.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3"
  }
