# Last local gate before code reaches the remote. Mirrors the CI "Quality"
# job (.github/workflows/ci.yml) so failures surface here — in seconds — rather
# than on a red main after Vercel has already deployed. pre-commit + lint-staged
# only touches *staged* files; this re-checks the whole tree on every push.
pnpm format:check && pnpm lint && pnpm typecheck && pnpm test
