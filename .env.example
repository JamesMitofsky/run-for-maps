# --- OSM OAuth2 (required for writing fountain status back to OSM) ---
# Register an OAuth2 app at your OSM account: Settings -> OAuth 2 applications.
#   Redirect URI: http://localhost:3000/api/osm/callback
#   Scopes: read_prefs, write_api
#   Confidential: NO (PKCE public client) — leave OSM_CLIENT_SECRET unset.
# Register on the SANDBOX first: https://master.apis.dev.openstreetmap.org
OSM_CLIENT_ID=
# Only set if you registered a confidential client:
OSM_CLIENT_SECRET=

# --- Which OSM server to talk to ---
# SANDBOX (safe, default for both): edits do NOT touch the real map.
OSM_OAUTH_BASE=https://master.apis.dev.openstreetmap.org
OSM_API_BASE=https://master.apis.dev.openstreetmap.org
# LIVE (real edits) — switch to these only after testing on sandbox:
#   OSM_OAUTH_BASE=https://www.openstreetmap.org
#   OSM_API_BASE=https://api.openstreetmap.org

# --- Optional service overrides ---
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# BROUTER_URL=https://brouter.de/brouter
# BROUTER_PROFILE=hiking-beta   # foot profile available on public brouter.de
